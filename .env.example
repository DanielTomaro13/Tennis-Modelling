# Bookmaker auth for src/odds.py — copy to ".env" (gitignored) or, preferred, put
# these in the shared ~/sports-bots/secrets.env that AFL/NRL/Tennis all source.
# Load locally with:  set -a; source .env; set +a   then:  python -m src.odds
#
# Sportsbet, Ladbrokes and PointsBet need NO auth. Only TAB and Dabble do.

# TAB (Tabcorp) — OAuth2 client credentials; the code mints a fresh token each run.
TAB_CLIENT_ID=
TAB_CLIENT_SECRET=
# ...or a short-lived access token instead of the client creds:
TAB_ACCESS_TOKEN=

# Dabble (iOS app) — Bearer token captured from the app (~1h lifetime). Required
# for Dabble match prices AND the ATP/WTA Pick'em player-prop lines.
DABBLE_AUTH=
# DABBLE_DEVICE_ID=   # optional, from the app's x-device-id header
# DABBLE_COOKIE=      # optional
